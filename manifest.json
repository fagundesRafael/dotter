{
    "manifest_version": 3,
    "name": "dotter",
    "version": "1.0",
    "description": "Auxiliar atividades de uma Delegacia de Polícia com análise de PDFs e relatórios via Gemini.",
    "permissions": ["storage"],
    "action": {
        "default_popup": "popup.html"
      },
      "icons": {
        "16": "icon16.png",
        "48": "icon48.png",
        "128": "icon128.png"
      }
      
  }
  